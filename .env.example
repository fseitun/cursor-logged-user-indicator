# Copy to .env (gitignored).

# Open VSX — get token: https://open-vsx.org/user-settings/tokens
OVSX_PAT=

# Optional alias if you prefer this name (script maps it to OVSX_PAT):
# OPENVSX_TOKEN=

# Visual Studio Marketplace — npm run publish:vscode
# https://code.visualstudio.com/api/working-with-extensions/publishing-extension
# VSCE_PAT=

# Optional: path to env file when not using default .env (relative to repo root or absolute):
# OVSX_DOTENV=.env.local
# VSCODE_DOTENV=.env.local
